# Database Configuration
DB_NAME=expense_tracker_auth
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# OAuth2 Providers - GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth2 Providers - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth2 Providers - Facebook
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Authentication Server Configuration
AUTH_ISSUER_URI=http://localhost:9000
VERIFICATION_BASE_URL=http://host.docker.internal:9000/api/auth/verify-email
FRONTEND_BASE_URL=http://localhost:5173

# One-Time Admin Bootstrap (optional)
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-with-at-least-12-chars
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrator
ADMIN_BOOTSTRAP_RESET_PASSWORD=false

# OAuth2 Client Registration (for this service as an auth server)
AUTH_CLIENT_ENABLED=true
AUTH_CLIENT_ID=expense-tracker-web
AUTH_CLIENT_SECRET=change-me-client-secret
AUTH_CLIENT_PUBLIC_CLIENT=true
AUTH_CLIENT_REDIRECT_URIS=http://localhost:5173/auth/callback
AUTH_CLIENT_POST_LOGOUT_REDIRECT_URIS=http://localhost:5173/logout
AUTH_CLIENT_SCOPES=openid,profile

# CORS Configuration
ALLOWED_ORIGIN_PATTERNS=http://localhost:5173

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP Configuration (for email verification)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USERNAME=your-email@gmail.com
#SMTP_PASSWORD=your-app-specific-password

# use dummy for now
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false
MAIL_HEALTH_ENABLED=false

# OpenTelemetry Configuration
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev

# JWK Set Location (optional, for custom key management)
JWK_SET_LOCATION=

# Server Configuration
SERVER_PORT=9000
